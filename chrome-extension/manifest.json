{
    "manifest_version": 3,
    "name": "LamHy.Store Extension",
    "version": "1.0",
    "description": "Thêm sản phẩm từ Kiotviet vào Website",
    "permissions": [
        "contextMenus",
        "activeTab",
        "storage",
        "notifications",
        "scripting"
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "*://*.kiotviet.vn/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}